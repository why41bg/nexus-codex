# 服务监听端口
PORT=3000

# 单次请求超时时间（毫秒），默认 5 分钟
# REQUEST_TIMEOUT_MS=300000

# 账号池排队超时时间（毫秒），默认 30 秒
# ACQUIRE_TIMEOUT_MS=30000

# 单账号默认最大并发数，默认 1（向后兼容），建议设为 3
# DEFAULT_MAX_CONCURRENCY=1

# 管理面板登录凭据（不设置则使用默认值 admin/admin，生产环境务必修改）
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-password

# 管理面板 session 过期时间（毫秒），默认 24 小时
# ADMIN_SESSION_TTL_MS=86400000

# 日志级别（debug / info / warn / error），默认 info
# LOG_LEVEL=info

# 日志格式：不设置则自动使用彩色 pretty 格式（TTY 终端），设为 json 强制输出 JSON 格式（适合日志采集）
# LOG_FORMAT=json

# 速率限制：单个 API Key 在时间窗口内的最大请求数，默认 60 次/分钟
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000

# ─── Thread 池化配置 ───────────────────────────────────────────
# 是否启用 Thread 池化复用（feature flag），默认 false
# THREAD_POOL_ENABLED=false

# 每个 (account, model) 组合最多保留的空闲 Thread 数，默认 2
# THREAD_POOL_MAX_IDLE=2

# Thread 最大存活时间（毫秒），默认 30 分钟
# THREAD_POOL_MAX_AGE_MS=1800000

# 单个 Thread 最大复用次数，默认 50
# THREAD_POOL_MAX_USAGE=50

# API Key 和模型白名单已迁移到 data/config.json，通过管理面板配置
# 首次启动时访问 http://localhost:3000/admin 进行初始化设置
