# Server
PORT=3000
HOST=0.0.0.0

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Account pool
DEFAULT_MAX_CONCURRENCY=1
ACQUIRE_TIMEOUT_MS=30000

# Request timeout (5 minutes)
REQUEST_TIMEOUT_MS=300000

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty

# Health check
HEALTH_LOCAL_INTERVAL_MS=60000
HEALTH_REMOTE_INTERVAL_MS=900000
HEALTH_TOKEN_EXPIRY_BUFFER_SEC=300
HEALTH_FAIL_THRESHOLD=2
